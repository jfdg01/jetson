# Python
.venv/
.venv-ft/
smolvlm_ft/
smolvlm_ft3/
smolvlm_ft4/
__pycache__/
*.pyc
.pytest_cache/

# Stage 3 model artifacts — merged checkpoint + GGUF exports (multi-GB binaries,
# exceed GitHub's 100 MB per-file limit). Kept locally + on the Jetson; not committed.
*.gguf

# Datasets (COCO train2014, VisDrone, RefDrone cache) — tens of GB, not thesis source.
# Anchored to repo root so it does NOT swallow the grounding/data/ package.
/data/
# Full VisDrone release (CC/DET/MOT/SOT/VID + toolkit, ~100 GB) and the raw aerial
# source videos sampled for the demo — VisDrone-derived, not thesis source. The small
# committed demo clips live under results/2026-06-25-system-demo/clips/ (not ignored).
/VisDrone/
/examples/

# Run outputs: training checkpoints under runs/ are multi-GB binaries, but the
# per-run PROVENANCE (manifest.json / run-card.md / results.json — the v2
# experiment-tracking record) must stay committed. Ignore everything in runs/
# except those text artifacts.
runs/**
!runs/**/
!runs/**/manifest.json
!runs/**/run-card.md
!runs/**/results.json

# Secrets
.hugging-face-token

# Large binary footprint files — G2/G3 raw --no-mmap dumps are multi-GB binary blobs
# that exceed GitHub's 100 MB per-file limit. Keep them locally; don't commit.
# (G4/G5 footprint files are plain text at ~100-150 KB and are fine to commit.)
results/2026-06-14-gemma-family-sweep/raw/2026-06-14_gsweepG2_footprint.txt
results/2026-06-14-gemma-family-sweep/raw/2026-06-14_gsweepG3_footprint.txt

# OS / editor noise
.DS_Store
*.swp
*~

# Stray hardware dumps (e.g. eeprom reads) — not thesis content
eeprom.bin

# Auto-continuation runtime state (logs, sentinels, locks) — mechanism in scripts/ is committed
.auto-continue/
